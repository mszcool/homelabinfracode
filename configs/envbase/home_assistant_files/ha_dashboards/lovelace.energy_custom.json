{
  "version": 1,
  "minor_version": 1,
  "key": "lovelace.energy_custom",
  "data": {
    "config": {
      "views": [
        {
          "type": "sections",
          "sections": [
            {
              "type": "grid",
              "cards": [
                {
                  "type": "energy-date-selection",
                  "vertical_opening_direction": "auto",
                  "opening_direction": "center",
                  "grid_options": {
                    "columns": 12,
                    "rows": 1
                  }
                },
                {
                  "type": "custom:tesla-style-solar-power-card",
                  "name": "Energy Flows Now (by 1-2 min. precise)",
                  "grid_options": {
                    "columns": 12,
                    "rows": "auto"
                  },
                  "grid_to_house_entity": "sensor.evcc_grid_to_house",
                  "grid_to_battery_entity": "sensor.evcc_grid_to_battery",
                  "generation_to_grid_entity": "sensor.evcc_solar_to_grid",
                  "generation_to_battery_entity": "sensor.evcc_solar_to_battery",
                  "generation_to_house_entity": "sensor.evcc_solar_to_house",
                  "battery_to_house_entity": "sensor.evcc_battery_to_house",
                  "battery_to_grid_entity": "sensor.evcc_battery_to_grid",
                  "grid_entity": "sensor.evcc_evcc_grid_power",
                  "generation_entity": "sensor.evcc_evcc_pv_power_total",
                  "house_entity": "sensor.evcc_evcc_home_power",
                  "battery_entity": "sensor.evcc_evcc_battery_power",
                  "battery_extra_entity": "sensor.evcc_evcc_battery_state_of_charge",
                  "show_gap": true,
                  "threshold_in_k": 1
                },
                {
                  "type": "energy-distribution",
                  "title": "Daily Production, Daily Consumption",
                  "grid_options": {
                    "rows": "auto",
                    "columns": 12
                  }
                }
              ]
            },
            {
              "type": "grid",
              "square": false,
              "columns": 1,
              "grid_options": {
                "columns": "full",
                "rows": 5
              },
              "cards": [
                {
                  "type": "power-sources-graph",
                  "title": "Energy Daily Usage Flow",
                  "grid_options": {
                    "columns": "full",
                    "rows": 8
                  },
                  "show_legend": true
                },
                {
                  "type": "custom:apexcharts-card",
                  "header": {
                    "show": true,
                    "title": "Battery Status",
                    "show_states": true,
                    "colorize_states": true
                  },
                  "grid_options": {
                    "columns": 24
                  },
                  "apex_config": {
                    "chart": {
                      "height": "350px"
                    }
                  },
                  "graph_span": "24h",
                  "all_series_config": {
                    "stroke_width": 2,
                    "group_by": {
                      "func": "avg",
                      "duration": "5m"
                    },
                    "show": {
                      "in_header": false
                    }
                  },
                  "series": [
                    {
                      "entity": "sensor.evcc_evcc_battery_state_of_charge",
                      "name": "Charged Capacity",
                      "type": "area",
                      "color": "green",
                      "yaxis_id": "pct",
                      "opacity": 0.35,
                      "stroke_width": 2,
                      "group_by": {
                        "func": "last",
                        "duration": "5m"
                      },
                      "show": {
                        "in_header": true
                      }
                    },
                    {
                      "entity": "sensor.evcc_battery_charge_power",
                      "name": "Battery Charge",
                      "type": "line",
                      "color": "blue",
                      "yaxis_id": "w",
                      "show": {
                        "in_header": true
                      }
                    },
                    {
                      "entity": "sensor.evcc_battery_discharge_power",
                      "name": "Battery Discharge",
                      "type": "line",
                      "color": "red",
                      "yaxis_id": "w",
                      "show": {
                        "in_header": true
                      }
                    }
                  ],
                  "yaxis": [
                    {
                      "id": "pct",
                      "show": true,
                      "opposite": true,
                      "decimals": 0,
                      "max": 100,
                      "min": 0
                    },
                    {
                      "id": "w",
                      "show": true,
                      "decimals": 0,
                      "min": 0,
                      "align_to": 100
                    }
                  ]
                },
                {
                  "type": "custom:apexcharts-card",
                  "section_mode": true,
                  "grid_options": {
                    "columns": "full",
                    "rows": 6
                  },
                  "header": {
                    "show": true,
                    "title": "Power Statistics Inverter House",
                    "show_states": true,
                    "colorize_states": true
                  },
                  "graph_span": "12h",
                  "all_series_config": {
                    "type": "area",
                    "opacity": 0.1,
                    "stroke_width": 1,
                    "group_by": {
                      "func": "last",
                      "duration": "5m"
                    }
                  },
                  "series": [
                    {
                      "entity": "sensor.evcc_evcc_pv_inverter_1_power",
                      "name": "Inverter Garage",
                      "color": "blue"
                    },
                    {
                      "entity": "sensor.evcc_evcc_pv_inverter_2_power",
                      "name": "Inverter House",
                      "color": "green"
                    }
                  ]
                }
              ],
              "column_span": 2
            },
            {
              "type": "grid",
              "cards": [
                {
                  "type": "energy-solar-consumed-gauge",
                  "title": "Solar Home Usage",
                  "grid_options": {
                    "rows": 3,
                    "columns": 12
                  }
                },
                {
                  "type": "energy-usage-graph",
                  "title": "Energy Usage"
                },
                {
                  "type": "energy-solar-graph",
                  "title": "Solar Production",
                  "grid_options": {
                    "rows": "auto",
                    "columns": 12
                  }
                }
              ]
            },
            {
              "type": "grid",
              "cards": [],
              "column_span": 2
            }
          ],
          "header": {
            "card": {
              "type": "markdown",
              "text_only": true,
              "content": "# Current Energy Flows\nShows current solar production, grid consumption, battery state ✨"
            }
          },
          "footer": {},
          "max_columns": 4,
          "title": "Default",
          "cards": []
        }
      ]
    }
  }
}
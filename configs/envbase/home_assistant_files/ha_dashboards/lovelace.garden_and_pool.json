{
  "version": 1,
  "minor_version": 1,
  "key": "lovelace.garden_and_pool",
  "data": {
    "config": {
      "views": [
        {
          "type": "sections",
          "sections": [
            {
              "type": "grid",
              "cards": [
                {
                  "type": "heading",
                  "heading_style": "title",
                  "heading": "Garten Hauptwasser (LinkTap oberer Bereich)"
                },
                {
                  "type": "tile",
                  "grid_options": {
                    "columns": 9,
                    "rows": 1
                  },
                  "entity": "input_boolean.garden_water_mainwater_desired_state",
                  "name": "Schalter auf An/Aus stellen",
                  "icon": "mdi:water-outline",
                  "vertical": false,
                  "features_position": "bottom"
                },
                {
                  "type": "tile",
                  "entity": "binary_sensor.garten_hauptwasser_3da6c335004b1200_is_watering",
                  "name": "Wasser läuft?",
                  "state_content": [
                    "last_changed",
                    "state"
                  ],
                  "vertical": false,
                  "features_position": "bottom"
                },
                {
                  "type": "tile",
                  "entity": "binary_sensor.garten_hauptwasser_3da6c335004b1200_is_manual_mode",
                  "name": "manuell geschalten?",
                  "icon": "mdi:account-hard-hat",
                  "hide_state": false,
                  "state_content": [
                    "last_changed",
                    "state"
                  ],
                  "vertical": false,
                  "tap_action": {
                    "action": "more-info"
                  },
                  "icon_tap_action": {
                    "action": "more-info"
                  },
                  "features_position": "bottom",
                  "grid_options": {
                    "columns": 9,
                    "rows": 1
                  }
                },
                {
                  "type": "tile",
                  "entity": "input_boolean.attribute_water_to_pool",
                  "name": "Wasser Pool zuordnen",
                  "vertical": false,
                  "features_position": "bottom",
                  "grid_options": {
                    "columns": 9,
                    "rows": 1
                  }
                },
                {
                  "type": "tile",
                  "entity": "sensor.garten_hauptwasser_3da6c335004b1200_battery",
                  "name": "Batteriestand",
                  "vertical": false,
                  "features_position": "bottom"
                },
                {
                  "type": "tile",
                  "grid_options": {
                    "columns": 6,
                    "rows": 1
                  },
                  "entity": "sensor.garten_hauptwasser_3da6c335004b1200_total_duration",
                  "name": "letzte Laufzeit",
                  "vertical": false,
                  "features_position": "bottom"
                }
              ],
              "column_span": 4
            },
            {
              "type": "grid",
              "cards": [
                {
                  "type": "heading",
                  "heading": "Garten Wassertimer und Zähler"
                },
                {
                  "type": "custom:apexcharts-card",
                  "header": {
                    "show": true,
                    "title": "Water Consumption",
                    "show_states": true,
                    "colorize_states": true
                  },
                  "grid_options": {
                    "square": false,
                    "columns": "full"
                  },
                  "graph_span": "1h",
                  "apex_config": {
                    "chart": {
                      "height": "315px"
                    }
                  },
                  "series": [
                    {
                      "entity": "sensor.garden_water_current_cycle",
                      "color": "lightblue"
                    }
                  ]
                },
                {
                  "type": "custom:apexcharts-card",
                  "header": {
                    "show": true,
                    "title": "Water Consumption Monthly",
                    "show_states": true,
                    "colorize_states": true
                  },
                  "grid_options": {
                    "square": false,
                    "columns": 12
                  },
                  "apex_config": {
                    "chart": {
                      "height": "315x"
                    }
                  },
                  "graph_span": "1y",
                  "span": {
                    "end": "month"
                  },
                  "series": [
                    {
                      "entity": "sensor.garden_water_monthly",
                      "type": "column",
                      "group_by": {
                        "duration": "1month",
                        "func": "max"
                      },
                      "color": "lightblue"
                    }
                  ]
                },
                {
                  "type": "custom:apexcharts-card",
                  "header": {
                    "show": true,
                    "title": "Pool Water Consumption Monthly",
                    "show_states": true,
                    "colorize_states": true
                  },
                  "grid_options": {
                    "square": false,
                    "columns": 12
                  },
                  "apex_config": {
                    "chart": {
                      "height": "315x"
                    }
                  },
                  "graph_span": "1y",
                  "span": {
                    "end": "month"
                  },
                  "series": [
                    {
                      "entity": "sensor.pool_water_monthly",
                      "type": "column",
                      "group_by": {
                        "duration": "1month",
                        "func": "max"
                      },
                      "unit": "L",
                      "color": "blue"
                    }
                  ]
                }
              ],
              "column_span": 2
            },
            {
              "type": "grid",
              "cards": [
                {
                  "type": "heading",
                  "heading": "Pool Statistiken",
                  "heading_style": "title"
                },
                {
                  "type": "custom:apexcharts-card",
                  "header": {
                    "show": true,
                    "title": "Pool Current Water Fill Flow",
                    "show_states": true,
                    "colorize_states": true
                  },
                  "grid_options": {
                    "square": false,
                    "columns": 24
                  },
                  "graph_span": "1h",
                  "apex_config": {
                    "chart": {
                      "height": "315px"
                    }
                  },
                  "series": [
                    {
                      "entity": "sensor.pool_water_current_fill",
                      "color": "blue"
                    }
                  ]
                },
                {
                  "type": "custom:apexcharts-card",
                  "header": {
                    "show": true,
                    "title": "Pool Tank Level (cm to ground)",
                    "show_states": true,
                    "colorize_states": true
                  },
                  "grid_options": {
                    "square": false,
                    "columns": 24
                  },
                  "graph_span": "24h",
                  "yaxis": [
                    {
                      "id": "depthCm",
                      "min": 20,
                      "max": 80,
                      "apex_config": {
                        "stepSize": 5,
                        "reversed": true
                      }
                    }
                  ],
                  "apex_config": {
                    "chart": {
                      "height": "315px"
                    },
                    "annotations": {
                      "position": "back",
                      "yaxis": [
                        {
                          "y": 30,
                          "borderColor": "blue",
                          "strokeDashArray": 5,
                          "label": {
                            "text": "Maximum fill ~30cm from top"
                          }
                        },
                        {
                          "y": 70,
                          "borderColor": "red",
                          "strokeDashArray": 5,
                          "label": {
                            "text": "Minimum fill ~70cm from ground (needs re-fill)"
                          }
                        }
                      ]
                    }
                  },
                  "series": [
                    {
                      "entity": "sensor.pool_tank_depth_sensor_pool_tank_water_level",
                      "color": "cyan",
                      "yaxis_id": "depthCm"
                    }
                  ]
                }
              ],
              "column_span": 2
            }
          ],
          "header": {
            "card": {
              "type": "markdown",
              "text_only": true,
              "content": "# Garden and Pool Water Statistics"
            }
          }
        }
      ]
    }
  }
}
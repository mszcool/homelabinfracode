                      "height": "315px",
                      "toolbar": {
                        "show": true,
                        "tools": {
                          "zoom": true,
                          "zoomin": true,
                          "zoomout": true,
                          "pan": true,
                          "reset": true
                        }
                      },
                      "zoom": {
                        "enabled": true,
                        "type": "x",
                        "autoScaleYaxis": true
                      }
                    }
                  },
                  "series": [
                    {
                      "entity": "sensor.switch_pumplight_pumplight_power",
                      "name": "Pump, Light",
                      "color": "darkred"

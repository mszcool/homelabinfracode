                },
                {
                  "type": "tile",
                  "entity": "input_boolean.garden_water_counter_1_target",
                  "name": "Gartenwasser Schalter",
                  "icon": "mdi:water-outline",
                  "vertical": false,
                  "features_position": "bottom"
                },
                {
                  "type": "tile",
                  "entity": "input_boolean.garden_water_counter_1_human_priority",
                  "name": "Manuelle Bedienung (Garten)",
                  "icon": "mdi:account-hard-hat",
                  "vertical": false,
                  "features_position": "bottom"
                },
                {
                  "type": "tile",
                  "entity": "input_boolean.attribute_water_to_pool",
                  "name": "Wasser Pool zuordnen",
                  "vertical": false,
                  "features_position": "bottom"
                },
                {
                  "type": "tile",
                  "entity": "sensor.garden_water_counter_1_battery",
                  "name": "Batterie Wasser Garten",
                  "vertical": false,
                  "features_position": "bottom"
                },
                {
                  "type": "tile",
                  "entity": "sensor.garden_water_counter_1_last_irrigation_duration",
                  "name": "Letzte Laufzeit",
                  "vertical": false,
                  "features_position": "bottom"
                }
              ],
              "column_span": 4
            },
            {
              "type": "grid",
              "cards": [
                {
                  "type": "heading",
                  "heading": "Garten Wassertimer und Zähler"
                },
                {
                  "type": "custom:apexcharts-card",
                  "header": {
                    "show": true,
                    "title": "Water Consumption",
                    "show_states": true,
                    "colorize_states": true
                  },
                  "grid_options": {
                    "square": false,
                    "columns": "full"
                  },
                  "graph_span": "1h",
                  "apex_config": {
                    "chart": {
                      "height": "315px"
                    }
                  },
                  "series": [
                    {
                      "entity": "sensor.garden_water_current_cycle",
                      "color": "lightblue"
                    }
                  ]
                },
                {
                  "type": "custom:apexcharts-card",
                  "header": {
                    "show": true,
                    "title": "Water Consumption Monthly",
                    "show_states": true,
                    "colorize_states": true
                  },
                  "grid_options": {
                    "square": false,
                    "columns": 12
                  },
                  "apex_config": {
                    "chart": {
                      "height": "315x"
                    }
                  },
                  "graph_span": "1y",
                  "span": {
                    "end": "month"
                  },
                  "series": [
                    {
                      "entity": "sensor.garden_water_monthly",
                      "type": "column",
                      "group_by": {
                        "duration": "1month",
                        "func": "max"
                      },
                      "color": "lightblue"
                    }
                  ]
                },
                {
                  "type": "custom:apexcharts-card",
                  "header": {
                    "show": true,
                    "title": "Pool Water Consumption Monthly",
                    "show_states": true,
                    "colorize_states": true
                  },
                  "grid_options": {
                    "square": false,
                    "columns": 12
                  },
                  "apex_config": {
                    "chart": {
                      "height": "315x"
                    }
                  },
                  "graph_span": "1y",
                  "span": {
                    "end": "month"
                  },
                  "series": [
                    {
                      "entity": "sensor.pool_water_monthly",
                      "type": "column",
                      "group_by": {
                        "duration": "1month",
                        "func": "max"
                      },
                      "unit": "L",
                      "color": "blue"
                    }
                  ]
                }
              ],
              "column_span": 2
            },
            {
              "type": "grid",
              "cards": [
                {
                  "type": "heading",
                  "heading": "Pool Statistiken",
                  "heading_style": "title"
                },
                {
                  "type": "custom:apexcharts-card",
                  "header": {
                    "show": true,
                    "title": "Pool Current Water Fill Flow",
                    "show_states": true,
                    "colorize_states": true
                  },
                  "grid_options": {
                    "square": false,
                    "columns": 24
                  },
                  "graph_span": "1h",
                  "apex_config": {
                    "chart": {
                      "height": "315px"
                    }
                  },
                  "series": [
                    {
                      "entity": "sensor.pool_water_current_fill",
                      "color": "blue"
                    }
                  ]
                },
                {
                  "type": "custom:apexcharts-card",
                  "header": {
                    "show": true,
                    "title": "Pool Tank Level (cm to ground)",
                    "show_states": true,
                    "colorize_states": true
                  },
                  "grid_options": {
                    "square": false,
                    "columns": 24
                  },
                  "graph_span": "24h",
                  "apex_config": {
                    "chart": {
                      "height": "315px"
                    },
                    "yaxis": {
                      "reversed": true,
                      "min": 0,
                      "max": 90
                    }
                  },
                  "series": [
                    {
                      "entity": "sensor.pool_tank_depth_sensor_pool_tank_water_level",
                      "color": "cyan"
                    }
                  ]
                }
              ],
              "column_span": 2
            }
          ],
          "header": {
            "card": {
              "type": "markdown",
              "text_only": true,
              "content": "# Garden and Pool Water Statistics"
            }
          }
        }
      ]
    }
  }
}
                  "icon": "mdi:ph",
                  "vertical": false,
                  "features_position": "bottom"
                },
                {
                  "type": "tile",
                  "entity": "switch.switch_pumplight_pool_light",
                  "name": "Pool Licht",
                  "icon": "mdi:lightbulb-auto-outline",
                  "vertical": false,
                  "features_position": "bottom"
                }
              ],
              "column_span": 4
            },
            {
              "type": "grid",
              "cards": [
                {
                  "type": "heading",
                  "heading": "Garten Wassertimer und Zähler"
                },
                {
                  "type": "custom:apexcharts-card",
                  "header": {
                    "show": true,
                    "title": "Water Consumption",
                    "show_states": true,
                    "colorize_states": true
                  },
                  "grid_options": {
                    "square": false,
                    "columns": "full"
                  },
                  "graph_span": "1h",
                  "apex_config": {
                    "chart": {
                      "height": "315px",
                      "toolbar": {
                        "show": true,
                        "tools": {
                          "zoom": true,
                          "zoomin": true,
                          "zoomout": true,
                          "pan": true,
                          "reset": true
                        }
                      },
                      "zoom": {
                        "enabled": true,
                        "type": "x",
                        "autoScaleYaxis": true
                      }
                    }
                  },
                  "series": [
                    {
                      "entity": "sensor.garden_water_current_cycle",
                      "color": "lightblue"
                    }
                  ]
                },
                {
                  "type": "custom:apexcharts-card",
                  "header": {
                    "show": true,
                    "title": "Water Consumption Monthly",
                    "show_states": true,
                    "colorize_states": true
                  },
                  "grid_options": {
                    "square": false,
                    "columns": 12
                  },
                  "apex_config": {
                    "chart": {
                      "height": "315x"
                    }
                  },
                  "graph_span": "1y",
                  "update_interval": "1h",
                  "span": {
                    "end": "month"
                  },
                  "series": [
                    {
                      "entity": "sensor.garden_water_monthly",
                      "type": "column",
                      "group_by": {
                        "duration": "1month",
                        "func": "max"
                      },
                      "color": "lightblue"
                    }
                  ]
                },
                {
                  "type": "custom:apexcharts-card",
                  "header": {
                    "show": true,
                    "title": "Pool Water Consumption Monthly",

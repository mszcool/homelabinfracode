---
# Template: Centralized secrets file
#
# Copy this file to your environment inventory's group_vars/all/secrets-vault.yaml:
#
#   cp configs/envbase/group_vars/all/secrets-vault.yaml.example \
#      configs/<env>/inventory/group_vars/all/secrets-vault.yaml
#
# By default, use 1Password lookups (requires op_vault_name in secrets-config.yaml
# and OP_SERVICE_ACCOUNT_TOKEN environment variable):
#
#   vault_incus_root_user_password: "{{ lookup('community.general.onepassword', 'Incus Root Password', field='password', vault=op_vault_name) }}"
#
# To use ansible-vault instead:
#   1. Replace each lookup() with the actual secret value
#   2. Encrypt:  ansible-vault encrypt <this-file>
#   3. Run with:  --ask-vault-pass  or  --vault-password-file
#
# Variable mapping (vault_* variable → default 1Password item name):
#   vault_incus_root_user_password   → "Incus Root Password"
#   vault_router_root_password       → "Router Root Password"
#   vault_router_automation_password → "Router Automation Password"
#   vault_edge_wifi_password         → "WiFi Password"
#   vault_samba4_admin_password      → "Samba4 Domain Admin Password"
#   vault_truenas_admin_password     → "TrueNAS Admin Password"
#   vault_identity_user_passwords    → Per-user items (e.g. "TrueNAS Mario")

# ---------- Incus bare-metal host credentials ----------
vault_incus_root_user_password: "{{ lookup('community.general.onepassword', 'Incus Root Password', field='password', vault=op_vault_name) }}"

# ---------- Router credentials ----------
vault_router_root_password: "{{ lookup('community.general.onepassword', 'Router Root Password', field='password', vault=op_vault_name) }}"
vault_router_automation_password: "{{ lookup('community.general.onepassword', 'Router Automation Password', field='password', vault=op_vault_name) }}"

# ---------- Edge device credentials ----------
vault_edge_wifi_password: "{{ lookup('community.general.onepassword', 'WiFi Password', field='password', vault=op_vault_name) }}"

# ---------- Identity provider credentials ----------
vault_samba4_admin_password: "{{ lookup('community.general.onepassword', 'Samba4 Domain Admin Password', field='password', vault=op_vault_name) }}"

# ---------- TrueNAS credentials ----------
vault_truenas_admin_password: "{{ lookup('community.general.onepassword', 'TrueNAS Admin Password', field='password', vault=op_vault_name) }}"

# ---------- Per-user AD passwords ----------
# Map of username -> password for identity lifecycle management.
# Only users listed here will have their passwords set/updated.
# Users not in this map will be created with a random password.
vault_identity_user_passwords:
  exampleuser: "{{ lookup('community.general.onepassword', 'Example User AD Account', field='password', vault=op_vault_name) }}"

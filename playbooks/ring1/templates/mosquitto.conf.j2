# Mosquitto MQTT Broker Configuration
# Managed by Ansible — do not edit manually
#
# Template: playbooks/ring1/templates/mosquitto.conf.j2
# Variables: configs/envbase/group_vars/incus_scope/apps-mosquitto-configuration.yaml

# ---------- Listener ----------
listener {{ mosquitto_config.listener_port | default(1883) }}
protocol mqtt

{% if mosquitto_config.websocket_enabled | default(false) %}
# WebSocket listener
listener {{ mosquitto_config.websocket_port | default(9001) }}
protocol websockets
{% endif %}

# ---------- Persistence ----------
persistence {{ 'true' if mosquitto_config.persistence_enabled | default(true) else 'false' }}
persistence_location /mosquitto/data/

# ---------- Logging ----------
log_dest file /mosquitto/log/mosquitto.log
log_type {{ mosquitto_config.log_type | default('warning') }}
connection_messages true
log_timestamp true
log_timestamp_format %Y-%m-%dT%H:%M:%S

# ---------- Authentication ----------
{% if mosquitto_config.allow_anonymous | default(false) %}
allow_anonymous true
{% else %}
allow_anonymous false
password_file /mosquitto/config/passwd
{% endif %}

# ---------- Authorization (ACL) ----------
{% if not (mosquitto_config.allow_anonymous | default(false)) %}
acl_file /mosquitto/config/acl.acl
{% endif %}

# ---------- Connection limits ----------
max_connections {{ mosquitto_config.max_connections | default(-1) }}
max_inflight_messages {{ mosquitto_config.max_inflight_messages | default(20) }}
max_queued_messages {{ mosquitto_config.max_queued_messages | default(1000) }}

{#
  EVCC configuration for the evcc container.

  References:
    - https://docs.evcc.io/en/docs/installation/configuration
    - https://docs.evcc.io/en/docs/devices/meters#sun2000-hybrid-inverter

  Generated by Ansible from
    configs/envbase/group_vars/incus_scope/apps-evcc-configuration.yaml
  and the matching environment override. Do not edit by hand inside the
  container — changes will be overwritten on the next playbook run.

  NOTE: The EVCC admin password cannot be set via this file or env-var.
  Set it on first launch through the Web UI at http://<container-ip>:7070/.
#}
# ---------------------------------------------------------------------------
# Global settings
# ---------------------------------------------------------------------------
network:
  schema: {{ evcc_network.schema }}
  host: {{ evcc_network.host }}
  port: {{ evcc_network.port }}

interval: {{ evcc_interval }}

# log: info
# levels:
#   site: debug
#   modbus: trace

# ---------------------------------------------------------------------------
# Meters (Huawei SUN2000 hybrid + PV-only inverter)
#
# Connect directly to each Huawei SUN2000 SDongleA — the dongle does not
# tolerate Modbus/TCP requests forwarded through a proxy.
# ---------------------------------------------------------------------------
meters:
{% for meter in evcc_meters %}
  - name: {{ meter.name }}
    type: {{ meter.type }}
    template: {{ meter.template }}
    usage: {{ meter.usage }}
    modbus: {{ meter.modbus }}
    host: {{ meter.host }}
    port: {{ meter.port }}
    id: {{ meter.id }}
{%   if meter.timeout is defined %}
    timeout: {{ meter.timeout }}
{%   endif %}
{%   if meter.maxchargepower is defined %}
    maxchargepower: {{ meter.maxchargepower }}
{%   endif %}
{%   if meter.capacity is defined %}
    capacity: {{ meter.capacity }}
{%   endif %}
{% endfor %}

# ---------------------------------------------------------------------------
# Site (binds meters into the EVCC dashboard)
# ---------------------------------------------------------------------------
{% if evcc_site is defined %}
site:
  title: {{ evcc_site.title | default('HomeLab') }}
  meters:
{%   if evcc_site.meters.grid is defined %}
    grid: {{ evcc_site.meters.grid }}
{%   endif %}
{%   if evcc_site.meters.pv is defined %}
    pv:
{%     for m in evcc_site.meters.pv %}
      - {{ m }}
{%     endfor %}
{%   endif %}
{%   if evcc_site.meters.battery is defined %}
    battery:
{%     for m in evcc_site.meters.battery %}
      - {{ m }}
{%     endfor %}
{%   endif %}
{% endif %}

# ---------------------------------------------------------------------------
# MQTT integration (optional)
# Publishes evcc values to the configured root topic and accepts commands.
# See https://docs.evcc.io/en/docs/reference/configuration/mqtt
# ---------------------------------------------------------------------------
{% if evcc_mqtt is defined and evcc_mqtt.host is defined and evcc_mqtt.host | length > 0 %}
mqtt:
  broker: {{ evcc_mqtt.host }}:{{ evcc_mqtt.port | default(1883) }}
  topic: {{ evcc_mqtt.topic | default('evcc') }}
{%   if evcc_mqtt.user is defined and evcc_mqtt.user | length > 0 %}
  user: {{ evcc_mqtt.user }}
{%   endif %}
{%   if evcc_mqtt.password is defined and evcc_mqtt.password | length > 0 %}
  password: {{ evcc_mqtt.password }}
{%   endif %}
{%   if evcc_mqtt.clientid is defined and evcc_mqtt.clientid | length > 0 %}
  clientid: {{ evcc_mqtt.clientid }}
{%   endif %}
{%   if evcc_mqtt.insecure is defined %}
  insecure: {{ evcc_mqtt.insecure | string | lower }}
{%   endif %}
{% endif %}

